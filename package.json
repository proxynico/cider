{
  "name": "cider",
  "version": "0.1.0",
  "description": "Apple MCP Server — Calendar, Reminders, Notes, Contacts via AppleScript/JXA",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build:swift": "swiftc -O src/helpers/cider-cal.swift -o src/helpers/cider-cal",
    "start": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "test": "bunx tsc --noEmit && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  }
}
